@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<h1>Welcome to the OWASP Lab</h1>
<p class="lead">This dashboard is intentionally insecure and is for training only.</p>

<div class="row">
    <div class="col-md-6">
        <h4>Try these endpoints</h4>
        <ul>
            <li><a href="/api/profile/1">/api/profile/1</a> - IDOR / A01</li>
            <li><a href="/api/user/2">/api/user/2</a> - IDOR / A01</li>
            <li><a href="/api/search?q=' OR 1=1 --">/api/search?q=' OR 1=1 --</a> - SQLi / A03</li>
            <li><a href="/api/greet?name=<script>alert(1)</script>">/api/greet?name=...</a> - Reflected XSS / A03</li>
            <li><a href="/Comments">/Comments</a> - Stored XSS / A03</li>
            <li><a href="/api/config">/api/config</a> - Sensitive data exposure / A05</li>
            <li><a href="/api/secrets">/api/secrets</a> - Hardcoded secrets / A07</li>
            <li><a href="/Vulnerabilities">/Vulnerabilities</a> - Full vulnerability catalog</li>
        </ul>
    </div>
    <div class="col-md-6">
        <h4>Send these requests</h4>
        <ul>
            <li>POST /api/transfer fromUserId=1&toUserId=999&amount=999999 - A04</li>
            <li>POST /Auth/Register with role=ADMIN, balance=999999 - A08</li>
            <li>POST /api/deserialize with arbitrary JSON - A08</li>
            <li>POST /upload with shell.aspx - A04 / A05</li>
            <li>GET /api/fetch?url=http://localhost:5000/api/config - A10</li>
        </ul>
    </div>
</div>
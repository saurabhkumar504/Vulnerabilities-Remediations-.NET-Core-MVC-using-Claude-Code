@model IEnumerable<OWASPDotNetLab.Controllers.VulnerabilityInfo>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Vulnerabilities";
}

<h1>Vulnerability Catalog</h1>
<p class="text-muted">
    This dashboard lists every intentional vulnerability planted in the lab,
    including its OWASP category, CWE, file location, endpoint, and a sample
    attack payload.
</p>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Vulnerability</th>
            <th>OWASP</th>
            <th>CWE</th>
            <th>File</th>
            <th>Endpoint</th>
            <th>Example Attack</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <td>@v.Name</td>
                <td>@v.Owasp</td>
                <td>@v.Cwe</td>
                <td><code>@v.File</code></td>
                <td><code>@v.Endpoint</code></td>
                <td><code>@v.Attack</code></td>
            </tr>
        }
    </tbody>
</table>
@model IEnumerable<OWASPDotNetLab.Models.User>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin";
}

<h2>Admin (no authorization)</h2>
<p class="text-warning">
    Vulnerable: this page is reachable by any user - no <code>[Authorize]</code>,
    no role check, no anti-forgery on mutating actions.
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Username</th>
            <th>Role</th>
            <th>Balance</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Username</td>
                <td>@u.Role</td>
                <td>@u.Balance</td>
                <td>@u.Email</td>
            </tr>
        }
    </tbody>
</table>
@model IEnumerable<OWASPDotNetLab.Models.Comment>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Comments";
}

<h2>Comments</h2>
<p class="text-warning">
    Vulnerable: comments are rendered with <code>Html.Raw(...)</code>.
    Try submitting a comment containing
    <code>&lt;script&gt;alert(document.cookie)&lt;/script&gt;</code>.
</p>

<form method="post" action="/Comments/Create" class="mb-4">
    <div class="mb-2">
        <label class="form-label">Author</label>
        <input class="form-control" name="author" />
    </div>
    <div class="mb-2">
        <label class="form-label">Body</label>
        <textarea class="form-control" name="body" rows="3"></textarea>
    </div>
    <button class="btn btn-primary" type="submit">Post comment</button>
</form>

<div>
    @foreach (var c in Model)
    {
        <div class="card mb-2">
            <div class="card-body">
                <h6 class="card-subtitle mb-1 text-muted">@c.Author</h6>
                <div class="card-text">
                    @* VULNERABILITY: CWE-79 / A03 - Stored XSS via @Html.Raw *@
                    @Html.Raw(c.Body)
                </div>
            </div>
        </div>
    }
</div>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "SSRF";
}

<h2>Server-Side Request Forgery</h2>
<p class="text-warning">
    Vulnerable: the <code>url</code> parameter is fetched server-side without
    validation. Internal services and cloud metadata are reachable.
</p>

<form id="ssrfForm" class="row g-2">
    <div class="col-auto flex-grow-1">
        <input class="form-control" name="url" id="url"
               placeholder="http://example.com" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" type="submit">Fetch</button>
    </div>
</form>
<pre id="result" class="mt-3"></pre>

<script>
    document.getElementById('ssrfForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        const url = document.getElementById('url').value;
        const res = await fetch('/api/fetch?url=' + encodeURIComponent(url));
        document.getElementById('result').textContent = await res.text();
    });
</script>
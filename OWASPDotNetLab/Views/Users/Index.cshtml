@model IEnumerable<OWASPDotNetLab.Models.User>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Users";
}

<h2>Users</h2>
<p class="text-warning">
    Vulnerable: passwords are stored and displayed in plaintext. This view
    exposes the entire user table without authorization.
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Username</th>
            <th>Password (plaintext)</th>
            <th>Email</th>
            <th>Role</th>
            <th>Balance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Username</td>
                <td>@u.Password</td>
                <td>@u.Email</td>
                <td>@u.Role</td>
                <td>@u.Balance</td>
            </tr>
        }
    </tbody>
</table>